# Corvus Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.

# ============================================================================
# CORE CONFIGURATION
# ============================================================================

# Data directory for SQLite and audit logs
CORVUS_DATA_DIR=/data

# Dev mode - set FALSE in production
# When true: allows anonymous access, disables auth
CORVUS_DEV_MODE=false

# Change window expiry (hours)
CORVUS_CHANGE_EXPIRY_HOURS=4

# ============================================================================
# AUTHENTICATION - API KEYS
# ============================================================================
# Format: key_name:key_type:role
# Roles: admin, ops-write, ops-read, agent
#
# Example:
# CORVUS_API_KEYS=corvus-admin:admin:admin,nemoclaw-agent:agent:ops-write,claude-code:agent:ops-write
#
# Generate keys securely:
# openssl rand -hex 32
#
# For each agent, create a unique key with appropriate role:
# - admin: Full access to all endpoints
# - ops-write: Can create changes, incidents, events (agent role)
# - ops-read: Read-only access to CMDB, events, metrics
# - agent: Scoped access for event emission and triage

CORVUS_API_KEYS=

# ============================================================================
# OIDC AUTHENTICATION (Optional - for human users)
# ============================================================================

OIDC_ENABLED=false
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ============================================================================
# SIEM FORWARDING (Optional)
# ============================================================================
# Forward OCSF-transformed events to your SIEM

CORVUS_SIEM_URL=
CORVUS_SIEM_TOKEN=

# ============================================================================
# LLM FOR RAG/KNOWLEDGE (Optional)
# ============================================================================
# URL to LLM API for knowledge retrieval and triage assistance

CORVUS_LLM_URL=

# ============================================================================
# NEO4J GRAPH DATABASE
# ============================================================================
# For CMDB relationship tracking and blast radius analysis

NEO4J_PASSWORD=changeme123

# ============================================================================
# MCP INTERNAL KEY
# ============================================================================
# Do not change - used for internal MCP server communication

CORVUS_MCP_INTERNAL_KEY=corvus-mcp-internal
