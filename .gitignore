# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Linting / Formatting
.ruff_cache/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# OS
.DS_Store
Thumbs.db

# Claude Code (local dev config — not product artifacts)
.claude/worktrees/
.claude/settings.local.json

# MCP config (contains local URLs and paths)
.mcp.json

# Instance-specific hooks config (customer deployments)
corvus-hooks/config.local.*
corvus-hooks/.env

# Instance-specific infrastructure config (only .example is committed)
corvus-server/config/infrastructure.yaml

# Docker
*.log

# Environment
.env
.env.*
!.env.template
!.env.example

# Secrets (NEVER commit)
*credentials*
*secret*
*token*
*.pem
*.key

# Allow runbook files that match secret patterns
!corvus-server/runbooks/triage-secrets.yaml
